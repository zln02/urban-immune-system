{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(docker compose:*)",
      "Bash(sudo docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pre-commit:*)",
      "Bash(pip install:*)",
      "Bash(uvicorn:*)",
      "Bash(streamlit run:*)",
      "Bash(npm:*)",
      "Bash(kubectl:*)",
      "Bash(psql:*)",
      "Bash(curl:*)",
      "Bash(mkdir:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session_start_badge.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/save_session_memory.sh"
          }
        ]
      }
    ]
  }
}
