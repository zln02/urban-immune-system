# === Database ===
DB_PASSWORD=changeme_local

# === Naver API (Layer 1 & 3) ===
NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

# === Anthropic (RAG Report — claude-sonnet-4-6 기본) ===
# 실 키 형식 placeholder 금지 (detect-secrets baseline 오염 방지)
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
LLM_MODEL=claude-sonnet-4-6

# === LLM 선택 (RAG 리포트) ===
LLM_PROVIDER=openai                         # openai | anthropic
OPENAI_MODEL=gpt-4o-mini                    # 비용 절감 (mini 권장)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # Haiku 권장

# === KMA Weather API ===
KMA_API_KEY=your_key

# === Mapbox (Deck.gl) ===
NEXT_PUBLIC_MAPBOX_TOKEN=<YOUR_MAPBOX_PUBLIC_TOKEN>

# === App Settings ===
STREAMLIT_PORT=8501
BACKEND_PORT=8000
ENVIRONMENT=development

# 외부 호스트 (로컬 개발: localhost, 데모: VM IP)
UIS_HOST=localhost
