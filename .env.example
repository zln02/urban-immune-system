# === Database ===
DB_PASSWORD=changeme_local

# === Naver API (Layer 1 & 3) ===
NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

# === Anthropic (RAG Report — Haiku 4.5 기본) ===
# 실 키 형식 placeholder 금지 (detect-secrets baseline 오염 방지)
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
LLM_MODEL=claude-haiku-4-5-20251001

# === LLM 선택 (RAG 리포트) ===
LLM_PROVIDER=anthropic                      # anthropic | openai
OPENAI_MODEL=gpt-4o-mini                    # legacy fallback only
ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # 비용·지연 균형 default

# === KMA Weather API ===
KMA_API_KEY=your_key

# === KCDC ILI / DATA.GO.KR (감염병예방법 ILI 검증) ===
# data.go.kr 공공데이터포털 API 키 — KCDC 인플루엔자 ILI rate 수집용
# pipeline/collectors/kcdc_collector.py 에서 사용
DATA_GO_KR_API_KEY=your_data_go_kr_key

# === Mapbox (Deck.gl) ===
NEXT_PUBLIC_MAPBOX_TOKEN=<YOUR_MAPBOX_PUBLIC_TOKEN>

# === ML Service ===
ML_SERVICE_URL=http://127.0.0.1:8002

# === App Settings ===
STREAMLIT_PORT=8501
BACKEND_PORT=8000
ENVIRONMENT=development

# 외부 호스트 (로컬 개발: localhost, 데모: VM IP)
UIS_HOST=localhost
