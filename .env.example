# === Database ===
DB_PASSWORD=changeme_local

# === Naver API (Layer 1 & 3) ===
NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

# === OpenAI (RAG Report) ===
OPENAI_API_KEY=sk-...

# === Anthropic (Optional) ===
ANTHROPIC_API_KEY=sk-ant-...

# === KMA Weather API ===
KMA_API_KEY=your_key

# === Mapbox (Deck.gl) ===
NEXT_PUBLIC_MAPBOX_TOKEN=pk...

# === App Settings ===
STREAMLIT_PORT=8501
BACKEND_PORT=8000
ENVIRONMENT=development

# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# === Qdrant (RAG 벡터 DB) ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=uis_docs

# === LLM (RAG Report Generator) ===
LLM_MODEL=gpt-4o-mini
